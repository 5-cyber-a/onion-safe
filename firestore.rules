rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /sites/{siteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // Simplified for now, add manager checks later
    }

    match /sites/{siteId}/equipment/{equipmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /monitoring_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn(); // Should be restricted to suppliers/admin
    }
    
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }
  }
}
